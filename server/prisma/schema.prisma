generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 1. КОРИСТУВАЧІ (Клієнти та Адміни)
model User {
  id       Int      @id @default(autoincrement())
  email    String   @unique
  password String
  fullName String?
  role     Role     @default(USER) // Роль: USER або ADMIN
  orders   Order[]  // Зв'язок із замовленнями
  createdAt DateTime @default(now())
  favorites Product[] @relation("UserFavorites")
  reviews   Review[]
  cartItems CartItem[]
  phone     String?
  address   String?
  resetPasswordToken   String?
  resetPasswordExpires DateTime?
}

enum Role {
  USER
  ADMIN
}

// 2. ТОВАРИ
model Product {
  id          Int      @id @default(autoincrement())
  title       String
  slug        String   @unique
  price       Decimal
  images      String[]
  description String?
  favoritedBy User[] @relation("UserFavorites")
  reviews       Review[]
  cartItems CartItem[]
  
  stock       Int      @default(10) // Скільки штук є на складі (по дефолту 10)
  soldCount   Int      @default(0)  // Скільки разів купили (для статистики)
  
  // Характеристики JSON (для фільтрів)
  specifications Json? 

  categoryId  Int
  category    Category @relation(fields: [categoryId], references: [id])
  
  orderItems  OrderItem[] // Зв'язок, щоб знати, в яких замовленнях є цей товар
  createdAt   DateTime @default(now())
}

// 3. КАТЕГОРІЇ
model Category {
  id       Int       @id @default(autoincrement())
  name     String    @unique
  slug     String    @unique
  products Product[]
}

// 4. ЗАМОВЛЕННЯ
model Order {
  id        Int         @id @default(autoincrement())
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  
  status    OrderStatus @default(PENDING)
  total     Float
  
  // Дані доставки
  fullName  String
  phone     String
  city      String
  address   String?     // Відділення або вулиця
  
  // Зв'язок з юзером (може бути null, якщо замовлення без реєстрації, але краще з нею)
  userId    Int?
  user      User?       @relation(fields: [userId], references: [id])
  
  items     OrderItem[]
  ttn       String?      // Номер ТТН після відправки замовлення
  // Для LiqPay
  paymentId String?     // ID транзакції в LiqPay
}

enum OrderStatus {
  PENDING
  PAID
  SHIPPED
  DELIVERED
  CANCELLED
}

// 5. ДЕТАЛІ ЗАМОВЛЕННЯ
model OrderItem {
  id        Int     @id @default(autoincrement())
  orderId   Int
  order     Order   @relation(fields: [orderId], references: [id])
  
  productId Int
  product   Product @relation(fields: [productId], references: [id])
  
  quantity  Int
  price     Float   // Фіксуємо ціну на момент покупки!
}
model Session {
  sid    String   @id @db.VarChar
  sess   Json     @db.Json
  expire DateTime @db.Timestamp(6)

  @@index([expire], name: "IDX_session_expire")
  @@map("session") // Це важливо: називаємо таблицю "session" з маленької літери
}

model Review {
  id        Int      @id @default(autoincrement())
  text      String
  rating    Int      @default(5) // Оцінка від 1 до 5
  createdAt DateTime @default(now())
  
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  
  productId Int
  product   Product  @relation(fields: [productId], references: [id])
}

model CartItem {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  
  productId Int
  product   Product  @relation(fields: [productId], references: [id])
  
  quantity  Int      @default(1)
  
  createdAt DateTime @default(now())

  @@unique([userId, productId]) // Щоб не дублювати товар в кошику одного юзера
}

